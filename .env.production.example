# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Set this to a comma-separated list of your deployed frontend URLs
# Example: https://dejenrewards-miniapp.onrender.com,https://dejenrewards-admin.onrender.com
ALLOWED_ORIGINS=""

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your_bot_token_here"
TELEGRAM_BOT_USERNAME="userdejenbot"
TELEGRAM_CHANNEL_ID="@yourchannelid"

# ─── Bot Service ──────────────────────────────────────────────────────────────
# Set to your deployed backend URL on Render
BACKEND_URL="https://dejenrewards-backend.onrender.com"
MINI_APP_URL="https://t.me/userdejenbot/app"

# ─── Mini App (Vite) ──────────────────────────────────────────────────────────
VITE_BACKEND_URL="https://dejenrewards-backend.onrender.com"

# ─── Admin Dashboard (Next.js) ────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL="https://dejenrewards-backend.onrender.com"
